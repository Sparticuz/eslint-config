{
  "name": "@sparticuz/eslint-config",
  "version": "11.0.2",
  "description": "Sparticuz's shareable config for eslint",
  "keywords": [
    "eslint",
    "config",
    "typescript",
    "eslint-config"
  ],
  "homepage": "https://github.com/Sparticuz/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/Sparticuz/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sparticuz/eslint-config.git"
  },
  "license": "ISC",
  "author": "Kyle McNally <kyle@kmcnally.net>",
  "type": "module",
  "exports": {
    ".": "./dist/base.js",
    "./css": "./dist/configs/css.js",
    "./import": "./dist/configs/import.js",
    "./json": "./dist/configs/json.js",
    "./markdown": "./dist/configs/markdown.js",
    "./package-json": "./dist/configs/package-json.js",
    "./react": "./dist/react.js",
    "./tailwind": "./dist/configs/tailwind.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist/** && tsc -p tsconfig.build.json",
    "lint": "eslint",
    "test": "npm run lint"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint-react/eslint-plugin": "^5.7.8",
    "@eslint-react/kit": "^5.7.8",
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-array-func": "^5.1.1",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-package-json": "^0.91.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^24.12.4",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.3.0"
  },
  "peerDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
