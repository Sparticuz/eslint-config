{
  "name": "@sparticuz/eslint-config",
  "version": "11.6.10",
  "description": "Sparticuz's shareable config for eslint",
  "keywords": [
    "eslint",
    "config",
    "typescript",
    "eslint-config"
  ],
  "homepage": "https://github.com/Sparticuz/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/Sparticuz/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sparticuz/eslint-config.git"
  },
  "license": "ISC",
  "author": "Kyle McNally <kyle@kmcnally.net>",
  "type": "module",
  "exports": {
    ".": "./dist/base.js",
    "./css": "./dist/configs/css.js",
    "./import": "./dist/configs/import.js",
    "./json": "./dist/configs/json.js",
    "./markdown": "./dist/configs/markdown.js",
    "./package-json": "./dist/configs/package-json.js",
    "./prettier": "./dist/configs/prettier.js",
    "./react": "./dist/react.js",
    "./tailwind": "./dist/configs/tailwind.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist/** && tsc -p tsconfig.build.json",
    "lint": "eslint",
    "test": "npm run lint"
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@eslint-react/kit": "^5.9.2",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@next/eslint-plugin-next": "^16.2.9",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-array-func": "^5.1.1",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-import": "^2.1.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^24.13.2",
    "@typescript-eslint/utils": "^8.62.0"
  },
  "peerDependencies": {
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
